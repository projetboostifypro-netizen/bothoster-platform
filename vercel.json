{
  "buildCommand": "pnpm --filter @workspace/bot-hosting run build",
  "outputDirectory": "artifacts/bot-hosting/dist/public",
  "installCommand": "npm install -g pnpm@9.15.4 && pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "build": {
    "env": {
      "VITE_API_URL": "https://git-hub-booster--abdramaneyimbou.replit.app"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}