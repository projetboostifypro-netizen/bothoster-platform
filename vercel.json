{
  "buildCommand": "pnpm --filter @workspace/bot-hosting run build",
  "outputDirectory": "artifacts/bot-hosting/dist/public",
  "installCommand": "npm install -g pnpm@9.15.4 && pnpm config set minimum-release-age 0 && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
